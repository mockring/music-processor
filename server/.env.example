# Server Configuration
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_EXPIRY=24h

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ytmusic

# 綠界ECPay
ECPAY_MERCHANT_ID=your_merchant_id
ECPAY_HASH_KEY=your_hash_key
ECPAY_HASH_IV=your_hash_iv
ECPAY_DEBUG=true
ECPAY_API_URL=https://payment.ecpay.com.tw

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# 訂閱方案價格 (分)
PRICE_MONTHLY=20000      # NT$200/月
PRICE_MONTHLY_ORIGINAL=25000
PRICE_YEARLY=210000      # NT$2,100/年
PRICE_YEARLY_ORIGINAL=270000
PRICE_LIFETIME=600000    # NT$6,000 永久
PRICE_LIFETIME_ORIGINAL=900000