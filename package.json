{
  "name": "music-processor",
  "version": "1.1.0",
  "description": "Music Ring - Audio processor with pitch shifting and vocal removal",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node start.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^25.9.8",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.3.9",
    "soundtouchjs": "^0.1.30"
  },
  "build": {
    "appId": "com.musicring.app",
    "productName": "Music Ring",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["arm64"]
        }
      ]
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "LICENSE.md",
        "to": "LICENSE.md",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "mockring",
      "repo": "music-processor"
    }
  }
}
